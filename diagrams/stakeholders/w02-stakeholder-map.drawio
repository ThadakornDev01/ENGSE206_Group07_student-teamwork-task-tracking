    <diagram id="stakeholder_map" name="Stakeholder Map">
        <mxGraphModel dx="1103" dy="804" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="1000" math="0" shadow="0">
