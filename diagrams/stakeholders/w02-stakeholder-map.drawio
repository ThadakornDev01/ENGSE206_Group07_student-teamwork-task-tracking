                <mxCell id="3" value="&lt;strong&gt;อำนาจสูง + ความสนใจต่ำ&lt;/strong&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
                    <mxGeometry x="130" y="150" width="100" height="50" as="geometry"/>
