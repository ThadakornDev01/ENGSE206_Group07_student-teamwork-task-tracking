                <mxCell id="4" value="&lt;strong&gt;อำนาจต่ำ + ความสนใจสูง&lt;/strong&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
